// Schema de datos del MVP de Liga SC.
// Diseñado para una única liga (sin multi-tenant) — ver documento de producto.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Usuarios (Admin / Mesa)
// ---------------------------------------------------------------------------

enum Rol {
  ADMIN
  MESA
}

// Perfil interno de la app, vinculado 1:1 al usuario de Supabase Auth.
// Supabase Auth es la fuente de verdad para email/password/sesión/seguridad;
// esta tabla solo guarda el rol y el estado dentro de la liga.
model Usuario {
  id             String   @id @default(cuid())
  supabaseUserId String   @unique
  email          String   @unique
  rol            Rol
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  partidosOperados   Partido[]         @relation("PartidoMesaOperador")
  eventosAnulados    MatchEvent[]      @relation("MatchEventAnuladoPor")
  informesArbitrales InformeArbitral[] @relation("InformeArbitralCreadoPor")

  @@map("usuarios")
}

// ---------------------------------------------------------------------------
// Clubes y jugadores
// ---------------------------------------------------------------------------

model Club {
  id        String   @id @default(cuid())
  nombre    String   @unique
  escudoUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jugadores             Jugador[]
  staff                 ClubStaff[]
  partidosComoLocal     Partido[]            @relation("PartidoClubLocal")
  partidosComoVisitante Partido[]            @relation("PartidoClubVisitante")
  rosterPartidos        PartidoJugador[]
  eventosDeEquipo       MatchEvent[]
  jugadorPartidoStats   JugadorPartidoStat[]

  @@map("clubes")
}

model Jugador {
  id             String   @id @default(cuid())
  clubId         String
  nombre         String
  // Nullable: el registro oficial de la liga no siempre trae dorsal asignado.
  // No se debe inventar un número — se completa después (import parcial o Admin/Mesa).
  numeroCamiseta Int?
  rut            String?
  fotoUrl        String?
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  club           Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  rosterPartidos PartidoJugador[]
  eventos        MatchEvent[]
  actasComoMvp   Acta[]
  stats          JugadorPartidoStat[]

  @@unique([clubId, numeroCamiseta])
  @@unique([clubId, rut])
  @@index([clubId])
  @@map("jugadores")
}

enum CargoStaff {
  ENTRENADOR
  AYUDANTE
}

// Cuerpo técnico de un club (entrenador/ayudantes). Sin UI todavía —
// se importa desde el registro oficial para no perder el dato.
model ClubStaff {
  id        String     @id @default(cuid())
  clubId    String
  cargo     CargoStaff
  nombres   String
  apellidos String
  rut       String?
  activo    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, rut])
  @@index([clubId])
  @@map("club_staff")
}

// ---------------------------------------------------------------------------
// Jornadas y partidos
// ---------------------------------------------------------------------------

model Jornada {
  id        String    @id @default(cuid())
  numero    Int       @unique
  // Nullable: el fixture real no siempre trae fecha definida al momento de crearse.
  // No se debe inventar una fecha — se completa después desde Admin.
  fecha     DateTime?
  nombre    String?
  createdAt DateTime  @default(now())

  partidos Partido[]

  @@map("jornadas")
}

enum EstadoPartido {
  PROGRAMADO
  CONFIRMADO
  EN_CURSO
  FINALIZADO
}

enum EstadoReloj {
  PAUSADO
  CORRIENDO
}

model Partido {
  id                    String        @id @default(cuid())
  jornadaId             String
  clubLocalId           String
  clubVisitanteId       String
  // Nullable por el mismo motivo que Jornada.fecha — el fixture real
  // importado no siempre trae fecha/hora definida todavía.
  fechaHora             DateTime?
  cancha                String?
  estado                EstadoPartido @default(PROGRAMADO)
  cuartoActual          Int           @default(0)
  duracionCuartoMinutos Int           @default(10)
  // Cronómetro del partido — la DB es la fuente de verdad (no el cliente).
  // relojRestanteSegundos = segundos que quedaban al último pause/reset/
  // cambio de cuarto. relojUltimoInicio = hora real del servidor cuando se
  // apretó Iniciar/Reanudar (solo tiene sentido si relojEstado=CORRIENDO).
  // El tiempo actual siempre se recalcula server-side: relojRestanteSegundos
  // - (ahora - relojUltimoInicio). Ver lib/mesa/reloj.ts. null en
  // relojRestanteSegundos = duracionCuartoMinutos*60 (no hace falta backfill).
  relojEstado           EstadoReloj   @default(PAUSADO)
  relojRestanteSegundos Int?
  relojUltimoInicio     DateTime?
  mesaOperadorId        String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  jornada         Jornada              @relation(fields: [jornadaId], references: [id], onDelete: Restrict)
  clubLocal       Club                 @relation("PartidoClubLocal", fields: [clubLocalId], references: [id], onDelete: Restrict)
  clubVisitante   Club                 @relation("PartidoClubVisitante", fields: [clubVisitanteId], references: [id], onDelete: Restrict)
  mesaOperador    Usuario?             @relation("PartidoMesaOperador", fields: [mesaOperadorId], references: [id], onDelete: SetNull)
  roster          PartidoJugador[]
  eventos         MatchEvent[]
  acta            Acta?
  informeArbitral InformeArbitral?
  jugadorStats    JugadorPartidoStat[]

  @@index([jornadaId])
  @@map("partidos")
}

// Roster de un partido: jugadores presentes/titulares y su estado en cancha.
model PartidoJugador {
  id        String  @id @default(cuid())
  partidoId String
  jugadorId String
  clubId    String
  presente  Boolean @default(false)
  titular   Boolean @default(false)
  // Cache operativo para que la UI de Mesa lea rápido "quién está en cancha".
  // NO es la fuente de verdad: ante cualquier duda o reconstrucción del partido,
  // la fuente de verdad son los eventos SUSTITUCION en MatchEvent.
  enCancha  Boolean @default(false)

  partido Partido @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  jugador Jugador @relation(fields: [jugadorId], references: [id], onDelete: Cascade)
  club    Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([partidoId, jugadorId])
  @@index([partidoId])
  @@map("partido_jugadores")
}

// ---------------------------------------------------------------------------
// Timeline del partido (event sourcing liviano)
// ---------------------------------------------------------------------------

enum TipoEvento {
  PUNTO
  FALTA
  TIMEOUT
  SUSTITUCION
  POSESION
  INICIO_CUARTO
  FIN_CUARTO
  FIN_PARTIDO
}

enum TipoFalta {
  PERSONAL
  TECNICA
  ANTIDEPORTIVA
  DESCALIFICANTE
  EXPULSION_DIRECTA
}

// Append-only: los eventos no se borran, se anulan (soft) para permitir
// que la Mesa corrija errores sin perder el registro auditable del partido.
model MatchEvent {
  id           String     @id @default(cuid())
  partidoId    String
  cuarto       Int
  tipo         TipoEvento
  // Jugador asociado al evento (punto, falta, jugador que sale en una sustitución).
  jugadorId    String?
  // Club asociado a eventos de equipo (timeout, posesión) o al jugador del evento.
  clubId       String?
  // Datos específicos del tipo de evento, ej:
  //   PUNTO: { valor: 2 }
  //   FALTA: { tipoFalta: "TECNICA" }
  //   SUSTITUCION: { jugadorEntraId: "..." }
  //   POSESION: { clubId: "..." }
  detalle      Json?
  anulado      Boolean    @default(false)
  anuladoPorId String?
  anuladoAt    DateTime?
  createdAt    DateTime   @default(now())

  partido    Partido  @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  jugador    Jugador? @relation(fields: [jugadorId], references: [id], onDelete: SetNull)
  club       Club?    @relation(fields: [clubId], references: [id], onDelete: SetNull)
  anuladoPor Usuario? @relation("MatchEventAnuladoPor", fields: [anuladoPorId], references: [id], onDelete: SetNull)

  @@index([partidoId])
  @@map("match_events")
}

enum OrigenStat {
  // Cargado por Mesa en vivo y derivable desde MatchEvent (Fase 2 en adelante).
  EVENTOS
  // Cargado por una importación de datos históricos agregados (ej. Fecha 1),
  // sin timeline — nunca se sintetizan MatchEvent falsos para representar esto.
  IMPORTADO
}

// Box score agregado por jugador y partido. Existe como modelo separado de
// MatchEvent para partidos sin timeline (datos históricos importados): permite
// guardar "N puntos en este partido" sin inventar un evento que nunca ocurrió.
// Para partidos operados en vivo por Mesa, el box score se deriva de MatchEvent
// y no necesariamente necesita filas acá (a definir en Fase 3 — Acta).
model JugadorPartidoStat {
  id        String     @id @default(cuid())
  partidoId String
  jugadorId String
  clubId    String
  puntos    Int
  // Null = dato no disponible en la fuente (ej. faltas no se registraron en el import de Fecha 1).
  faltas    Int?
  origen    OrigenStat
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  partido Partido @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  jugador Jugador @relation(fields: [jugadorId], references: [id], onDelete: Cascade)
  club    Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([partidoId, jugadorId])
  @@index([partidoId])
  @@map("jugador_partido_stats")
}

// ---------------------------------------------------------------------------
// Acta e informe arbitral
// ---------------------------------------------------------------------------

// Generada automáticamente a partir de los eventos al finalizar el partido.
model Acta {
  id                 String   @id @default(cuid())
  partidoId          String   @unique
  generadaAt         DateTime @default(now())
  resultadoLocal     Int
  resultadoVisitante Int
  mvpJugadorId       String?
  observacionesMesa  String?

  partido    Partido  @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  mvpJugador Jugador? @relation(fields: [mvpJugadorId], references: [id], onDelete: SetNull)

  @@map("actas")
}

// Se completa solo si corresponde (expulsión, incidente, reclamo, etc.).
model InformeArbitral {
  id          String   @id @default(cuid())
  partidoId   String   @unique
  requerido   Boolean  @default(false)
  texto       String?
  creadoPorId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  partido   Partido  @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  creadoPor Usuario? @relation("InformeArbitralCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)

  @@map("informes_arbitrales")
}
