# Copiar este archivo a .env y completar con los valores reales.
# .env nunca se sube al repositorio (ver .gitignore).

# Cadena de conexión a Postgres.
# Si usás Supabase: Project Settings > Database > Connection string (modo "Transaction" o "Session").
# Formato general: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/liga_sc?schema=public"

# Supabase Auth. Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key"

# Service role key de Supabase — Project Settings > API > "service_role" "secret".
# NUNCA debe llevar el prefijo NEXT_PUBLIC_, nunca se expone al cliente,
# y solo se usa en Server Actions (ej. crear usuarios de Mesa desde Admin).
# Es la key con más privilegios del proyecto: tratala como una contraseña.
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key"
